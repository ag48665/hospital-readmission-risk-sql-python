(4, 'Luca Visser', 58, 'Male', 33.8, 'Current smoker', 1, 1, 1, 'Basic'),
(5, 'Mila Smit', 29, 'Female', 22.4, 'Never smoked', 0, 0, 0, 'Supplementary'),
(6, 'Noah Meijer', 81, 'Male', 30.6, 'Former smoker', 1, 1, 1, 'Basic'),
(7, 'Anna Bos', 67, 'Female', 27.9, 'Never smoked', 0, 1, 1, 'Basic'),

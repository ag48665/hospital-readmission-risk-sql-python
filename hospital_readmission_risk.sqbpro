(104, 4, 'Amsterdam UMC', '2024-01-15', '2024-01-24', 'Diabetes Complication', 9, 1, 15200, 1),
(105, 5, 'Leiden UMC', '2024-01-18', '2024-01-20', 'Minor Infection', 2, 0, 2100, 0),
(106, 6, 'Erasmus MC', '2024-01-22', '2024-02-03', 'Stroke', 12, 1, 23000, 1),
(107, 7, 'UMC Utrecht', '2024-01-25', '2024-01-30', 'Hypertension Crisis', 5, 0, 6900, 0),
(108, 8, 'Amsterdam UMC', '2024-02-01', '2024-02-08', 'Respiratory Failure', 7, 1, 16800, 1);






-- =====================================
-- INSERT MEDICATION DATA
-- Medication usage and adverse events
-- =====================================

INSERT INTO medications
(medication_id, patient_id, drug_name, dosage_mg, adverse_event)
VALUES
(201, 1, 'Metformin', 1000, 0),
(202, 2, 'Prednisone', 40, 1),
(203, 3, 'Amoxicillin', 500, 0),
(204, 4, 'Insulin', 50, 1),
(205, 5, 'Ibuprofen', 200, 0),
(206, 6, 'Warfarin', 5, 1),
(207, 7, 'Lisinopril', 20, 0),
(208, 8, 'Albuterol', 90, 1);




-- =====================================
-- HOSPITAL KPI ANALYSIS
-- Readmission rate, ICU rate, average stay and cost by hospital
-- =====================================

SELECT
    hospital_name,
    COUNT(*) AS total_admissions,
    ROUND(AVG(length_of_stay), 2) AS avg_length_of_stay,
    ROUND(AVG(total_cost), 2) AS avg_cost,
    ROUND(100.0 * AVG(icu_admission), 2) AS icu_rate_percent,
    ROUND(100.0 * AVG(readmitted_30_days), 2) AS readmission_rate_percent
FROM admissions
GROUP BY hospital_name
ORDER BY readmission_rate_percent DESC;







-- =====================================
-- READMISSION RISK SEGMENTATION
-- Segment patients by clinical and admission risk factors
-- =====================================

SELECT
    patients.full_name,
    patients.age,
    patients.bmi,
    patients.smoking_status,
    patients.diabetes,
    patients.hypertension,
    patients.chronic_disease,
    admissions.diagnosis,
    admissions.length_of_stay,
    admissions.icu_admission,
    admissions.readmitted_30_days,
    CASE
        WHEN patients.age &gt;= 70 
             AND patients.chronic_disease = 1 
             AND admissions.icu_admission = 1 THEN 'Very High Risk'
        WHEN patients.age &gt;= 60 
             OR admissions.length_of_stay &gt;= 7 
             OR patients.chronic_disease = 1 THEN 'High Risk'
        WHEN patients.diabetes = 1 
             OR patients.hypertension = 1 THEN 'Medium Risk'
        ELSE 'Low Risk'
    END AS readmission_risk_category
FROM patients
JOIN admissions
ON patients.patient_id = admissions.patient_id
ORDER BY readmission_risk_category DESC;




-- =====================================
-- CTE ANALYSIS
-- Identify high-risk readmission patients
-- =====================================

WITH patient_risk AS (
    SELECT
        patients.patient_id,
        patients.full_name,
        patients.age,
        patients.bmi,
        patients.diabetes,
        patients.hypertension,
        patients.chronic_disease,
        admissions.diagnosis,
        admissions.length_of_stay,
        admissions.icu_admission,
        admissions.total_cost,
        admissions.readmitted_30_days,
        CASE
            WHEN patients.age &gt;= 70 THEN 2 ELSE 0
        END +
        CASE
            WHEN patients.chronic_disease = 1 THEN 2 ELSE 0
        END +
        CASE
            WHEN admissions.icu_admission = 1 THEN 2 ELSE 0
        END +
        CASE
            WHEN admissions.length_of_stay &gt;= 7 THEN 1 ELSE 0
        END +
        CASE
            WHEN patients.diabetes = 1 THEN 1 ELSE 0
        END AS risk_score
    FROM patients
    JOIN admissions
    ON patients.patient_id = admissions.patient_id
)

SELECT *
FROM patient_risk
WHERE risk_score &gt;= 4
ORDER BY risk_score DESC;


-- =====================================
-- WINDOW FUNCTION ANALYSIS
-- Running hospital costs by patient
-- =====================================

SELECT
    patients.full_name,
    admissions.admission_date,
    admissions.total_cost,
    SUM(admissions.total_cost) OVER (
        PARTITION BY patients.patient_id
        ORDER BY admissions.admission_date
    ) AS cumulative_hospital_cost
FROM admissions
JOIN patients
ON admissions.patient_id = patients.patient_id;





-- =====================================
-- PATIENT COST RANKING
-- Rank patients by hospitalization cost
-- =====================================

SELECT
    patients.full_name,
    admissions.diagnosis,
    admissions.total_cost,
    RANK() OVER (
        ORDER BY admissions.total_cost DESC
    ) AS cost_rank
FROM admissions
JOIN patients
ON admissions.patient_id = patients.patient_id;















































































































-- =====================================
-- INSERT HOSPITAL ADMISSIONS DATA
-- Synthetic hospital admissions with 30-day readmission flag
-- =====================================

INSERT INTO admissions
(admission_id, patient_id, hospital_name, admission_date, discharge_date, diagnosis, length_of_stay, icu_admission, total_cost, readmitted_30_days)

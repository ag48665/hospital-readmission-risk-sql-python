-- PATIENT TABLE
-- Synthetic Dutch healthcare patients
-- =====================================

CREATE TABLE patients (
    patient_id INTEGER PRIMARY KEY,
    full_name TEXT,
    age INTEGER,
    sex TEXT,
    bmi REAL,
    smoking_status TEXT,
    diabetes INTEGER,
    hypertension INTEGER,
    chronic_disease INTEGER,
    insurance_type TEXT
);

-- =====================================
-- HOSPITAL ADMISSIONS
-- Admission history and outcomes
-- =====================================

CREATE TABLE admissions (
    admission_id INTEGER PRIMARY KEY,
    patient_id INTEGER,
    hospital_name TEXT,
    admission_date TEXT,
    discharge_date TEXT,
    diagnosis TEXT,
    length_of_stay INTEGER,
    icu_admission INTEGER,
    total_cost REAL,
    readmitted_30_days INTEGER,
    FOREIGN KEY (patient_id) REFERENCES patients(patient_id)
);

-- =====================================
-- MEDICATIONS TABLE
-- Treatment and medication data
-- =====================================

CREATE TABLE medications (
    medication_id INTEGER PRIMARY KEY,
    patient_id INTEGER,
    drug_name TEXT,
    dosage_mg INTEGER,
    adverse_event INTEGER,
    FOREIGN KEY (patient_id) REFERENCES patients(patient_id)
);



-- =====================================
-- INSERT PATIENT DATA
-- Synthetic patient-level healthcare dataset
-- =====================================

INSERT INTO patients
(patient_id, full_name, age, sex, bmi, smoking_status, diabetes, hypertension, chronic_disease, insurance_type)
VALUES
